# Tracking - Plano Performance
# GTM container ID (ex.: GTM-XXXXXXX)
VITE_GTM_ID=

# GA4 measurement ID (ex.: G-XXXXXXXXXX)
# Se usar GTM para enviar eventos ao GA4, pode deixar vazio.
VITE_GA4_ID=

# Use "true" apenas se quiser GA4 direto via gtag mesmo com GTM ativo.
VITE_GA4_DIRECT=false

# Meta Pixel ID (ex.: 123456789012345)
VITE_META_PIXEL_ID=
